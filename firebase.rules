rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin profile docs
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Legacy admin profile location
    match /main/admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Admin-only marketplace writes
    match /products/{document=**} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    match /listings/{document=**} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // Everything else default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

